{
  "compilerOptions": {
    "target": "ES2017",
    "module": "preserve",
    "lib": ["ES2017"],
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true
  },
  "include": ["index.d.ts", "types/**/*.d.ts"]
}
