{
  "compilerOptions": {
    "target": "es2017",
    "module": "node16",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node16",
    "outDir": "build/tmp",
    "rootDir": "src",
    "types": []
  },
  "include": ["src/**/*.ts"]
}
